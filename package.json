{
  "name": "setpower-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "test": "node tests/run-tests.js",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:landing": "node scripts/build-landing.js",
    "build:web": "expo export -p web --output-dir dist/app",
    "predeploy": "npm run build:landing && npm run build:web",
    "deploy": "node scripts/deploy-ghpages.js",
    "benchmark:exports": "node scripts/benchmark-exports.js",
    "bench:check": "node scripts/bench-compare.js",
    "encoding:check": "node scripts/encoding-gate.js",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "stress:exports": "node scripts/stress-exports.js",
    "perf:snapshot": "node scripts/perf-snapshot.js",
    "verify": "npm test && npm run encoding:check && npm run stress:exports && npm run perf:snapshot && npm run bench:check",
    "dev:backup": "node scripts/dev-backup.js",
    "dev:backup:once": "node scripts/dev-backup.js --once",
    "dev:snapshot": "node scripts/dev-snapshot.js",
    "dev:check": "node scripts/dev-check.js"
  },
  "dependencies": {
    "@expo-google-fonts/press-start-2p": "^0.4.1",
    "@expo-google-fonts/vt323": "^0.4.1",
    "@expo/metro-runtime": "~3.1.3",
    "@react-native-async-storage/async-storage": "1.21.0",
    "@react-native-community/netinfo": "^11.1.0",
    "@react-native-picker/picker": "2.6.1",
    "@types/react": "~18.2.45",
    "ci-info": "^3.9.0",
    "cli-spinners": "^2.9.2",
    "expo": "^50.0.0",
    "expo-clipboard": "^5.0.1",
    "expo-file-system": "~16.0.9",
    "expo-font": "~11.10.3",
    "expo-haptics": "~12.8.1",
    "expo-linear-gradient": "~12.7.2",
    "expo-location": "~16.5.1",
    "expo-print": "^12.8.0",
    "expo-sharing": "^11.7.0",
    "expo-sqlite": "~13.4.0",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-web": "~0.19.6",
    "typescript": "^5.3.0",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@babel/core": "^7.22.0",
    "gh-pages": "^6.2.0",
    "prettier": "^3.2.5",
    "sharp-cli": "^2.1.0"
  }
}
